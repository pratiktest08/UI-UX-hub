{
  "version": 2,
  "builds": [
    { "src": "api/claude.js",       "use": "@vercel/node" },
    { "src": "api/search.js",       "use": "@vercel/node" },
    { "src": "api/live-compare.js", "use": "@vercel/node" },
    { "src": "public/**",           "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude",        "dest": "/api/claude.js" },
    { "src": "/api/search",        "dest": "/api/search.js" },
    { "src": "/api/live-compare",  "dest": "/api/live-compare.js" },
    { "src": "/(.*)",              "dest": "/public/$1" }
  ]
}
